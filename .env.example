# Database (Railway PostgreSQL에서 자동 제공)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=8080
NODE_ENV=production
SESSION_SECRET=your-random-secret-here

# Auth
OWNER_PASSWORD=your-password-here

# Binance API
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_LIVE_MODE=false  # true로 바꾸면 실제 거래

# Anthropic AI
ANTHROPIC_API_KEY=

# Telegram (선택사항)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Logging
LOG_LEVEL=info
